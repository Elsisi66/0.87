# Required names (leave empty if unavailable)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Paper safety and runtime
PAPER_MODE=true
BINANCE_MODE=marketdata_only
START_EQUITY_EUR=320
DAILY_SUMMARY_HOUR_UTC=21
LOG_LEVEL=INFO

# Optional tuning
POLL_SECONDS=20
FEE_BPS=7
SLIPPAGE_BPS_CHOICES=2,5,7,10,12
RECONCILIATION_LOOKBACK_BARS=72
SYMBOL_ERROR_QUARANTINE_THRESHOLD=4
SYMBOL_QUARANTINE_MINUTES=120
API_CIRCUIT_FAIL_THRESHOLD=5
API_CIRCUIT_COOLDOWN_SEC=600
MAX_BARS_FETCH=1200
